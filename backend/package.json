{
  "name": "imara-links",
  "version": "2.0.0",
  "description": "IMARA LINKS - Local Desktop Application",
  "main": "electron-main.js",
  "homepage": "./",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "electron-dev": "electron ..",
    "electron-build": "electron-builder --config",
    "electron-build:win": "electron-builder --win",
    "electron-build:mac": "electron-builder --mac",
    "electron-build:linux": "electron-builder --linux",
    "build": "npm run electron-build:win"
  },
  "build": {
    "appId": "com.imara.links",
    "productName": "IMARA LINKS",
    "directories": {
      "app": "..",
      "buildResources": "../assets",
      "output": "dist"
    },
    "files": [
      "electron-main.js",
      "electron-is-dev.js",
      "preload.js",
      "backend/db/**/*",
      "backend/middleware/**/*",
      "backend/routes/**/*",
      "backend/package.json",
      "frontend/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "!node_modules/.cache/**/*",
      "!**/*.map",
      "!**/*.md",
      "!**/.git/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "IMARA LINKS",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    },
    "publish": {
      "provider": "github",
      "owner": "Deric254",
      "repo": "imara"
    }
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3",
    "electron-updater": "^6.1.8",
    "nodemon": "^3.0.1"
  }
}